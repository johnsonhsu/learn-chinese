# ─── Dependencies ───
node_modules/
**/node_modules/
.pnp
.pnp.js

# ─── Build output ───
dist/
**/dist/
build/
*.tsbuildinfo

# ─── Vite / PWA ───
.vite/
**/.vite/
dev-dist/
**/dev-dist/

# ─── Baked data assets (generated by `npm run bake:data`) ───
platform/public/data/
# NOTE: platform/public/stroke-data/ is intentionally NOT ignored — it holds
# hand-made Taiwan stroke OVERRIDES (為/說/齣…), committed so CI bundles them.
# Only /data/ below is generated output.

# ─── SQLite databases ───
# Local/runtime + generated DBs are ignored, EXCEPT platform/content.db — the
# curriculum the app needs to run (kept so the repo is reproducible end-to-end).
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
!platform/content.db
# Committed content-only seeds so CI can build without the working DBs.
# Scrubbed of personal data; regenerate with `npm run seed:dbs`.
!seed/platform.db
!seed/writing-challenge.db
# word-sets is pure content (categories/words) — no personal data.
!modules/word-sets/word-sets.db

# ─── Raw import sources (huge dictionaries; not committed — see README) ───
input-lists/

# ─── Env / secrets ───
.env
.env.*
!.env.example

# ─── Logs ───
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Backups (bank-fix.py snapshots, pre-cleanup copies, migration backups) ───
.backup-*/
**/.backup-*/
*.backup-*
*.db.backup*

# ─── Scratch / one-off (not part of the app) ───
# Branch handoff logs (AGENTS.md convention puts these in the repo PARENT folder;
# ignore any that land in-repo so a stray one never gets committed).
chatter.md
ux-plan.html
top-300-chars.csv
sentence-bank-todo.md
sentence-bank-accepted.tsv
scripts/generated-stories.txt
scripts/template-candidates.txt
# sentence-QA harness output (#74) — real run results + generated report are
# local review artifacts, never committed. The sample FIXTURE is committed.
scripts/sentence-qa-results/
.ref-frames/

# ─── Python cache (pytest/opencc) ───
__pycache__/
*.pyc

# ─── Claude Code local state ───
.claude/

# ─── OS / editor cruft ───
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Misc ───
coverage/
.cache/
tmp/
.wrangler/
