# Environment variables for the dev server (platform/server) and Pages Functions.
# Copy to `.env` and fill in. `.env` is git-ignored — never commit real secrets.
# Every key here is OPTIONAL: the app runs offline-first without any of them.

# ─── Feedback triage (admin panel) ───
# Shared secret the admin Feedback panel sends as `x-feedback-admin-secret`.
# Set to any random string; required only to VIEW/triage submitted feedback.
FEEDBACK_ADMIN_SECRET=

# ─── AI sentence generation (optional helpers; app works without them) ───
# Google Gemini — used by the optional sentence-generation proxy.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Cloudflare Workers AI — alternate generation backend.
CF_ACCOUNT_ID=
CF_AI_TOKEN=
