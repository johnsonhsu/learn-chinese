{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@platform/*": ["./src/*"],
      "@modules/*": ["../modules/*/src/index.ts"]
    }
  },
  "include": ["src", "../modules/*/src"]
}
