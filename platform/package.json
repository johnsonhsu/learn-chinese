{
  "name": "platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "bake:data": "tsx scripts/bake-data.ts",
    "build": "tsx scripts/bake-data.ts && vite build",
