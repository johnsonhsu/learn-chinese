# --- Baseline security headers (issue #54 / audit M1, see #51) ---
# Applied to every response. The CSP is built from what the app ACTUALLY loads
# (verified in the audit) — keep these notes in sync if the app's network/asset
# surface changes, or the PWA can break:
#   script-src  'self' + 'wasm-unsafe-eval'  -> sql.js compiles WebAssembly
#               (platform/src/offline/sql-db.ts). Without 'wasm-unsafe-eval' the
#               whole app fails to boot. No inline scripts ship (Vite emits
#               <script type=module src=...> only), so no 'unsafe-inline' for script.
#   style-src   'self' 'unsafe-inline' + jsdelivr -> Vite/React inject <style> and
#               ~22 inline style={} attrs ('unsafe-inline' is for STYLE ONLY, never
#               script); the landing page lazily injects the LXGW WenKai TC brush
#               webfont STYLESHEET from cdn.jsdelivr.net (LandingPage.tsx).
#   font-src    'self' + jsdelivr -> the .woff2 subset slices that webfont CSS pulls.
#   img-src     'self' data: blob: + own origin -> html-to-image feedback screenshots
#               (FeedbackWidget.tsx) produce data:/blob: images; og-image is same-origin.
#   connect-src 'self' + jsdelivr -> fetch() of hanzi-writer-data JSON
#               (DictionaryPanel.tsx) + SW runtime cache; /api/* Functions are 'self'.
#               (Gemini is server-side proxied via /api/copybook/*, so NOT listed.)
#   worker-src  'self' -> the vite-plugin-pwa / Workbox service worker.
# DELIBERATELY PERMISSIVE: style-src 'unsafe-inline' (React/Vite inline styles are
# pervasive; a nonce/hash rollout is a possible follow-up). Everything else is locked
# down (object-src 'none', frame-ancestors 'none', base-uri 'self').
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; img-src 'self' data: blob: https://learnchinese.hsu.mobi; connect-src 'self' https://cdn.jsdelivr.net; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# The version stamp must always revalidate so clients detect content updates.
# (The DB files themselves are cache-busted with ?v=<version> on download.)
/data/version.json
  Cache-Control: no-cache
